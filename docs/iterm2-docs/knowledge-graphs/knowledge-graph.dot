// iTerm2 Scripting Knowledge Graph
// Generated by project-20-iTerm2
// Render with: dot -Tpng knowledge-graph.dot -o knowledge-graph.png

digraph iTerm2_Knowledge {
    // Graph settings
    rankdir=TB;
    node [shape=box, style="rounded,filled", fontname="Helvetica"];
    edge [fontname="Helvetica", fontsize=10];

    // Color scheme
    node [fillcolor="#E8F4FD"];

    // Main categories
    subgraph cluster_approaches {
        label="Scripting Approaches";
        style=filled;
        fillcolor="#F0F8FF";

        python_api [label="Python API\n(26 modules)", fillcolor="#90EE90"];
        applescript [label="AppleScript\n(Deprecated)", fillcolor="#FFB6C1"];
        jxa [label="JXA\n(JavaScript)", fillcolor="#FFFFE0"];
        osascript [label="osascript\n(CLI Bridge)", fillcolor="#FFFFE0"];
    }

    subgraph cluster_objects {
        label="iTerm2 Object Model";
        style=filled;
        fillcolor="#FFF8DC";

        app [label="Application"];
        window [label="Window"];
        tab [label="Tab"];
        session [label="Session"];
    }

    subgraph cluster_features {
        label="Key Features";
        style=filled;
        fillcolor="#F0FFF0";

        split_panes [label="Split Panes"];
        shell_int [label="Shell Integration"];
        triggers [label="Triggers"];
        profiles [label="Profiles"];
        tmux [label="tmux Integration"];
    }

    subgraph cluster_issues {
        label="Known Issues";
        style=filled;
        fillcolor="#FFE4E1";

        tab_title [label="Tab Title Trap\n(Error -10000)"];
        apostrophe [label="Apostrophe\n(Error -2740)"];
        quote_hell [label="Quote Hell\n(Bash+AS)"];
    }

    // Relationships
    python_api -> app [label="controls"];
    applescript -> app [label="controls"];
    jxa -> app [label="controls"];
    osascript -> applescript [label="invokes"];

    app -> window [label="contains"];
    window -> tab [label="contains"];
    tab -> session [label="contains"];

    session -> split_panes [label="enables"];
    session -> shell_int [label="uses"];
    profiles -> triggers [label="contains"];
    session -> tmux [label="integrates"];

    applescript -> tab_title [label="causes", style=dashed, color=red];
    applescript -> apostrophe [label="causes", style=dashed, color=red];
    osascript -> quote_hell [label="causes", style=dashed, color=red];

    python_api -> tab_title [label="avoids", style=dotted, color=green];
    python_api -> apostrophe [label="avoids", style=dotted, color=green];
    python_api -> quote_hell [label="avoids", style=dotted, color=green];

    // Legend
    subgraph cluster_legend {
        label="Legend";
        style=filled;
        fillcolor="#FFFFFF";

        legend_modern [label="Modern/Recommended", fillcolor="#90EE90"];
        legend_deprecated [label="Deprecated", fillcolor="#FFB6C1"];
        legend_legacy [label="Legacy/Workaround", fillcolor="#FFFFE0"];
    }
}
